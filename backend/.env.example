PORT=5000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sanlam_chronic
DB_USER=postgres
DB_PASSWORD=yourpassword

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Email — Corporate SMTP
SMTP_HOST=mail.yourdomain.co.ug
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=systems@yourdomain.co.ug
SMTP_PASS=your_smtp_password

# TrueAfrican SMS API
SMS_API_URL=https://mysms.trueafrican.com/v1/api/esme/send
SMS_API_USERNAME=SanlamSMS
SMS_API_PASSWORD=your_sms_password

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email

# Frontend URL
FRONTEND_URL=http://localhost:5173
