PORT=5000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sanlam_chronic
DB_USER=postgres
DB_PASSWORD=yourpassword

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_key
JWT_EXPIRES_IN=7d

# Email — Corporate SMTP
SMTP_HOST=mail.yourdomain.co.ug
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=systems@yourdomain.co.ug
SMTP_PASS=your_smtp_password

# TrueAfrican SMS API
SMS_API_URL=https://mysms.trueafrican.com/v1/api/esme/send
SMS_API_USERNAME=SanlamSMS
SMS_API_PASSWORD=your_sms_password

# Firebase (Push Notifications) — choose one method
# Method 1: Full JSON string
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# Method 2: Individual variables
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY_ID=your_private_key_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=123456789
FIREBASE_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxx%40project.iam.gserviceaccount.com

# Frontend URL
FRONTEND_URL=http://localhost:5173
